{
    "_description": "train model with best hyper-parameters from tuning (replace defaults below)",
    
    "num_epochs": 500,
    "batch_size": 32,

    "ssim_loss_weight": 0.0,
    "mask_ratio": 0.0,
 
    "learn_rate": 1e-4,
    "weight_decay": 0.0,
    "optim_beta1": 0.9,
    "optim_beta2": 0.99,

    "hidden_factor": 2.0,
    "hidden_layers": 3,
    "hidden_dims": 256,
    "latent_dims": 128,
    "conv_kernel": 3,
    "conv_stride": 1,

    "apply_batchnorm": false,
    "apply_groupnorm": false,
    "activation_function": "relu",
    "negative_slope": 0.01,

    "enable_earlystop": true,
    "earlystop_patience": 20,
    "earlystop_min_delta": 0.0
}